# To use this file, copy it to `.env` and update and/or add your own values.
# Be sure to read the `Environment Variables` section in the README.

# Basic streaming configuration
# Webpage to capture and stream
WEBPAGE_URL="https://www.youtube.com/embed/xuCn8ux2gbs?autoplay=1&loop=1&playlist=xuCn8ux2gbs"
# RTMP endpoint to stream to (all tracks go to this single URL)
RTMP_URL=rtmp://localhost:1935/live/stream

# Stream output configuration (Enhanced RTMP multitrack)
# JSON array of video track configurations. Each track gets its own browser
# rendered at its native width/height (no scaling/cropping).
# The first track is the primary (carries audio).
#
# Example: desktop + Twitch vertical (9:16)
STREAM_OUTPUTS='[{"width":1920,"height":1080,"framerate":60,"videoBitrate":"6000k","name":"desktop-1080p60"},{"width":1080,"height":1920,"framerate":30,"videoBitrate":"4500k","name":"vertical-1080x1920"}]'

# Legacy single-output mode (only used when STREAM_OUTPUTS is not set)
# If you only need a single stream, you can remove STREAM_OUTPUTS above and
# uncomment these instead:
# RESOLUTION=720p
# FRAMERATE=30

# Optional configurations (uncomment to use)
# Webpage refresh interval in seconds (optional - if not set, automatic refresh is disabled)
# WEBPAGE_REFRESH_INTERVAL=120

# Logging configuration
# Log format (json or console) - default: json
# LOG_FORMAT=json
# Log level (debug, info, warn, warning, error, dpanic, panic, fatal) - default: info
# LOG_LEVEL=info

# HTTP server configuration
# Port for health and metrics endpoint - default: 8080
# PORT=8080

# Stream status checking configuration
# Cron schedule for checking stream status - default: */10 * * * * (every 10 minutes)
# STATUS_CRON_SCHEDULE="*/10 * * * *"

# Twitch Enhanced Broadcasting (multitrack via Go Live API)
# When enabled, the app calls Twitch's GetClientConfiguration API to get
# server-authorized multitrack config. RTMP_URL is ignored (derived from API).
# STREAM_OUTPUTS is still used to inform the API what canvas dimensions and
# orientation you want — include a portrait entry (height > width) to get
# vertical tracks automatically.
# TWITCH_ENHANCED_BROADCASTING=true
# TWITCH_STREAM_KEY=live_123456_YourStreamKeyHere
# Override the client name sent to the Go Live API (default: stream-webpage-container)
# TWITCH_CLIENT_NAME=stream-webpage-container
# x264 encoder preset. Faster presets use less CPU but lower quality.
# Options (fastest to slowest): ultrafast, superfast, veryfast, faster, fast, medium
# Default: ultrafast (recommended for multitrack to avoid frame drops)
# ENCODER_PRESET=ultrafast

# Twitch integration (all three required for Twitch status checking)
# Twitch channel name to monitor
# TWITCH_CHANNEL=your_channel_name
# Twitch Client ID from https://dev.twitch.tv/console
# TWITCH_CLIENT_ID=your_client_id
# Twitch Client Secret from https://dev.twitch.tv/console
# TWITCH_CLIENT_SECRET=your_client_secret
